<header class="site-header">
  <div class="header-inner">
    <a href="<%= url_for('/') %>" class="site-logo">
      <svg class="logo-svg" viewBox="0 0 60 60" width="48" height="48">
        <defs>
          <linearGradient id="logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" style="stop-color:#ff2d95"/>
            <stop offset="50%" style="stop-color:#bd00ff"/>
            <stop offset="100%" style="stop-color:#00d4ff"/>
          </linearGradient>
          <filter id="logo-glow">
            <feGaussianBlur stdDeviation="3" result="blur"/>
            <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
        </defs>
        <polygon points="30,5 55,25 55,50 30,55 5,50 5,25" fill="none" stroke="url(#logo-grad)" stroke-width="2.5" filter="url(#logo-glow)"/>
        <text x="30" y="36" text-anchor="middle" fill="url(#logo-grad)" font-family="JetBrains Mono" font-size="16" font-weight="bold" filter="url(#logo-glow)">NV</text>
      </svg>
      <span class="logo-text"><%= config.title %></span>
    </a>

    <nav class="site-nav">
      <% for (var i in theme.menu) { %>
        <a href="<%= url_for(theme.menu[i].split(' || ')[0]) %>" class="nav-link">
          <span class="nav-text"><%= theme.menu[i].split(' || ')[1] %></span>
          <span class="nav-hover"></span>
        </a>
      <% } %>
    </nav>

    <div class="header-actions">
      <button class="theme-toggle" id="theme-toggle" aria-label="切换主题">
        <svg class="sun-icon" viewBox="0 0 24 24" width="20" height="20"><circle cx="12" cy="12" r="5" fill="currentColor"/><g stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></g></svg>
        <svg class="moon-icon" viewBox="0 0 24 24" width="20" height="20"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" fill="currentColor"/></svg>
      </button>
      <button class="mobile-menu-toggle" id="mobile-toggle" aria-label="菜单">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="mobile-nav" id="mobile-nav">
    <% for (var i in theme.menu) { %>
      <a href="<%= url_for(theme.menu[i].split(' || ')[0]) %>"><%= theme.menu[i].split(' || ')[1] %></a>
    <% } %>
  </div>
</header>

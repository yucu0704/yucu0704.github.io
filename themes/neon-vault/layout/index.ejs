<%- partial('_partial/head') %>

<% if (is_home()) { %>
<div class="hero-section">
  <div class="hero-content">
    <div class="hero-badge">
      <span class="badge-dot"></span> EXPLORE THE DIGITAL REALM
    </div>
    <h1 class="hero-title">
      <span class="glitch-text" data-text="<%= config.title %>"><%= config.title %></span>
    </h1>
    <p class="hero-subtitle"><%= config.description %></p>
    <div class="hero-actions">
      <a href="<%= url_for('/archives') %>" class="btn-primary">
        <span>探索文章</span>
        <svg viewBox="0 0 24 24" width="18" height="18"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
      </a>
      <a href="<%= url_for('/about') %>" class="btn-secondary">
        <span>关于我</span>
      </a>
    </div>
  </div>
  <div class="hero-visual">
    <svg class="hero-geo" viewBox="0 0 400 400">
      <defs>
        <linearGradient id="hero-grad1" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#ff2d95" stop-opacity="0.3"/>
          <stop offset="100%" stop-color="#00d4ff" stop-opacity="0.1"/>
        </linearGradient>
      </defs>
      <circle cx="200" cy="200" r="180" fill="none" stroke="url(#hero-grad1)" stroke-width="0.5"/>
      <circle cx="200" cy="200" r="140" fill="none" stroke="#ff2d95" stroke-width="0.3" stroke-dasharray="4 8" opacity="0.4"/>
      <circle cx="200" cy="200" r="100" fill="none" stroke="#00d4ff" stroke-width="0.3" stroke-dasharray="2 6" opacity="0.5"/>
      <circle cx="200" cy="200" r="60" fill="none" stroke="#bd00ff" stroke-width="0.5" opacity="0.6"/>
      <g opacity="0.3">
        <line x1="200" y1="20" x2="200" y2="60" stroke="#ff2d95" stroke-width="0.5"/>
        <line x1="200" y1="340" x2="200" y2="380" stroke="#ff2d95" stroke-width="0.5"/>
        <line x1="20" y1="200" x2="60" y2="200" stroke="#00d4ff" stroke-width="0.5"/>
        <line x1="340" y1="200" x2="380" y2="200" stroke="#00d4ff" stroke-width="0.5"/>
      </g>
      <g opacity="0.2">
        <% for (var i = 0; i < 12; i++) { %>
          <circle cx="<%= 200 + 160 * Math.cos(i * Math.PI / 6) %>" cy="<%= 200 + 160 * Math.sin(i * Math.PI / 6) %>" r="3" fill="#bd00ff"/>
        <% } %>
      </g>
      <text x="200" y="208" text-anchor="middle" fill="#fff" font-family="JetBrains Mono" font-size="28" font-weight="bold" opacity="0.9">NV</text>
    </svg>
  </div>
</div>

<section class="posts-section">
  <div class="section-header">
    <h2 class="section-title">
      <span class="neon-line"></span> 最新文章 <span class="neon-line"></span>
    </h2>
  </div>

  <div class="posts-grid">
    <% page.posts.each(function(post) { %>
      <%- partial('_partial/post-card', { post: post }) %>
    <% }) %>
  </div>

  <%- partial('_partial/pagination') %>
</section>

<% } else if (is_post()) { %>
<%- partial('_partial/post-detail', { post: page }) %>

<% } else if (is_archive()) { %>
<div class="archive-page">
  <div class="page-hero">
    <h1 class="page-hero-title"><span class="glitch-text" data-text="文章归档">文章归档</span></h1>
    <p class="page-hero-desc">共 <%= site.posts.length %> 篇文章</p>
  </div>

  <div class="archive-timeline">
    <% var lastYear = 0; %>
    <% page.posts.each(function(post) { %>
      <% var thisYear = date(post.date, 'YYYY'); %>
      <% if (thisYear !== lastYear) { lastYear = thisYear; %>
        <div class="timeline-year">
          <span class="year-marker"></span>
          <h2><%= thisYear %></h2>
        </div>
      <% } %>
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <time class="timeline-date"><%= date(post.date, 'MM-DD') %></time>
          <a href="<%= url_for(post.path) %>" class="timeline-title"><%= post.title %></a>
          <% if (post.categories && post.categories.length) { %>
            <span class="timeline-cat">
              <% post.categories.each(function(cat) { %>
                <a href="<%= url_for(cat.path) %>"><%= cat.name %></a>
              <% }) %>
            </span>
          <% } %>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<% } else if (is_category()) { %>
<div class="page-hero">
  <h1 class="page-hero-title"><span class="glitch-text" data-text="分类">分类</span></h1>
</div>
<div class="category-grid">
  <% site.categories.each(function(cat) { %>
    <a href="<%= url_for(cat.path) %>" class="category-card">
      <span class="cat-icon"><%= cat.name.charAt(0) %></span>
      <div class="cat-info">
        <h3><%= cat.name %></h3>
        <span><%= cat.posts.length %> 篇文章</span>
      </div>
    </a>
  <% }) %>
</div>

<% } else if (is_tag()) { %>
<div class="page-hero">
  <h1 class="page-hero-title"><span class="glitch-text" data-text="标签">标签</span></h1>
</div>
<div class="tag-cloud-page">
  <% site.tags.each(function(tag) { %>
    <a href="<%= url_for(tag.path) %>" class="tag-bubble" style="--tag-size: <%= Math.min(2, Math.max(0.8, tag.posts.length / 5)) %>">
      <span class="tag-hash">#</span><%= tag.name %>
      <sup><%= tag.posts.length %></sup>
    </a>
  <% }) %>
</div>
<% } %>

<%- partial('_partial/footer') %>
